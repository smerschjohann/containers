#!/bin/bash

TOKEN=""
URL=""
ARGS=()

DEFAULT_ARIA_ARGS=(
    "-c"
    "-x16"
    "-s16"
    "-k1M"
    "--auto-file-renaming=false"
    "--allow-overwrite=true"
    "--file-allocation=falloc"
    "--console-log-level=warn"
    "--summary-interval=0"
)

while [[ $# -gt 0 ]]; do
  case $1 in
    -t|--token)
      TOKEN="$2"
      shift 2
      ;;
    *)
      if [ -z "$URL" ]; then
        URL="$1"
      else
        ARGS+=("$1")
      fi
      shift
      ;;
  esac
done

if [ -z "$URL" ]; then
  echo "Usage: dl [-t <token>] <URL> [aria2c-args...]"
  exit 1
fi

if [ -z "$TOKEN" ] && [[ "$URL" == *"huggingface.co"* ]] && [ -n "$HF_TOKEN" ]; then
    TOKEN="$HF_TOKEN"
fi

FILENAME=$(echo "$URL" | cut -d? -f1 | sed 's#/*$##' | rev | cut -d/ -f1 | rev)

if [ -n "$TOKEN" ]; then
    ARGS+=(--header="Authorization: Bearer $TOKEN")
fi

if [ -n "$FILENAME" ]; then
    echo "[$(date +%T)] Start: $FILENAME"
    ARGS+=("-o" "$FILENAME")
fi

# Ausführung mit allen Optimierungen
aria2c "${DEFAULT_ARIA_ARGS[@]}" "${ARGS[@]}" "$URL"

# Kurze Erfolgsmeldung nach Abschluss
if [ $? -eq 0 ]; then
    echo "[$(date +%T)] Fertig: $FILENAME"
else
    echo "[$(date +%T)] FEHLER: $FILENAME konnte nicht geladen werden."
fi
