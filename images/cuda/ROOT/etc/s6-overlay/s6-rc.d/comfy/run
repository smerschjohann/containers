#!/command/with-contenv sh
set -e

. /venv/main/bin/activate

case "${COMFYUI_ENABLED:-1}" in
    0|false|False|FALSE|no|No|NO|off|Off|OFF)
        echo "ComfyUI disabled via COMFYUI_ENABLED=${COMFYUI_ENABLED}"
    exec /usr/bin/sleep infinity
        ;;
esac

cd /opt/workspace-internal/ComfyUI/

mkdir -p /workspace/basedir
if [ ! -d /workspace/basedir/custom_nodes ]; then
    echo "custom_nodes directory does not exist in /workspace/basedir. Copying from /opt/workspace-internal/ComfyUI/custom_nodes."
    cp -a /opt/workspace-internal/ComfyUI/custom_nodes/. /workspace/basedir/
fi

export LD_PRELOAD=libtcmalloc_minimal.so.4

if [ "$SAGEATTENTION_USE" != "0" ] && { [ "$SAGEATTENTION_VERSION" = "v2" ] || [ "$SAGEATTENTION_VERSION" = "v3" ]; }; then
    exec python main.py --base-directory /workspace/basedir --use-sage-attention ${COMFYUI_VRAM_FLAG} ${COMFYUI_ARGS}
else
    exec python main.py --base-directory /workspace/basedir ${COMFYUI_VRAM_FLAG} ${COMFYUI_ARGS}
fi